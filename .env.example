# Pickup location (airport code or city name, e.g. "LAX" or "Los Angeles, CA")
PICKUP_LOCATION=LAX

# Pickup date in MM/DD/YYYY format
PICKUP_DATE=06/01/2026

# Pickup time (12-hour format, e.g. "10:00 AM")
PICKUP_TIME=10:00 AM

# Dropoff date in MM/DD/YYYY format
DROPOFF_DATE=06/07/2026

# Dropoff time (12-hour format, e.g. "10:00 AM")
DROPOFF_TIME=10:00 AM

# Optional: set to "false" to run browser in headed (visible) mode for debugging
HEADLESS=true

# Optional: set to "true" to stop immediately when Costco preflight checks fail
PREFLIGHT_STRICT=false

# Optional: proxy settings (useful if Costco blocks cloud/devcontainer IPs)
# PROXY_SERVER=http://host:port
# PROXY_USERNAME=myuser
# PROXY_PASSWORD=mypassword
